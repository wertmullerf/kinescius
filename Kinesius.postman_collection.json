            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/agenda/{{agendaId}}/recurrentes"
          }
        },
        {
          "name": "Listar patrones (como PROFESOR)",
          "request": {
            "method": "GET",
