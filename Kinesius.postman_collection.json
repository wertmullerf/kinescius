{
  "info": {
    "name": "Kinesius API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:3000/api" },
    { "key": "tokenAdmin",   "value": "" },
    { "key": "tokenProfesor","value": "" },
    { "key": "tokenCliente", "value": "" },
    { "key": "agendaId",     "value": "" },
    { "key": "patronId",     "value": "" },
    { "key": "instanciaId",  "value": "" },
    { "key": "sueltaId",     "value": "" },
    { "key": "profesorId",   "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (cliente nuevo)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Test\",\n  \"apellido\": \"Usuario\",\n  \"dni\": \"40123456\",\n  \"email\": \"test@mail.com\",\n  \"password\": \"test1234\"\n}"
            }
          }
        },
        {
          "name": "Login ADMIN",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('tokenAdmin', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"laura@kinesius.com\",\n  \"password\": \"admin1234\"\n}"
            }
          }
        },
        {
          "name": "Login PROFESOR",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('tokenProfesor', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"profesor@kinesius.com\",\n  \"password\": \"profesor1234\"\n}"
            }
          }
        },
        {
          "name": "Login CLIENTE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('tokenCliente', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos@mail.com\",\n  \"password\": \"cliente1234\"\n}"
            }
          }
        },
        {
          "name": "Me (token actual)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Profesores",
      "item": [
        {
          "name": "Listar profesores",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/profesores"
          }
        },
        {
          "name": "Listar profesores (como PROFESOR)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenProfesor}}" }],
            "url": "{{baseUrl}}/profesores"
          }
        },
        {
          "name": "Listar profesores (como CLIENTE — debe dar 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenCliente}}" }],
            "url": "{{baseUrl}}/profesores"
          }
        },
        {
          "name": "Crear profesor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('profesorId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/profesores",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Roberto\",\n  \"apellido\": \"Sánchez\",\n  \"dni\": \"28999000\"\n}"
            }
          }
        },
        {
          "name": "Ver profesor",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/profesores/{{profesorId}}"
          }
        },
        {
          "name": "Editar profesor",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/profesores/{{profesorId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Roberto\",\n  \"apellido\": \"Fernández\"\n}"
            }
          }
        },
        {
          "name": "Eliminar profesor",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/profesores/{{profesorId}}"
          }
        },
        {
          "name": "Crear profesor — DNI duplicado (debe dar error)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/profesores",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Otro\",\n  \"apellido\": \"Profesor\",\n  \"dni\": \"27100001\"\n}"
            }
          }
        },
        {
          "name": "Crear profesor — validación falla (DNI inválido)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/profesores",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Test\",\n  \"apellido\": \"Test\",\n  \"dni\": \"ABC\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Agenda",
      "item": [
        {
          "name": "Listar agendas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/agenda"
          }
        },
        {
          "name": "Crear agenda (mes actual)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const now = new Date();",
                  "pm.variables.set('mesActual',  now.getMonth() + 1);",
                  "pm.variables.set('anioActual', now.getFullYear());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('agendaId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/agenda",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mes\": {{mesActual}},\n  \"anio\": {{anioActual}}\n}"
            }
          }
        },
        {
          "name": "Crear agenda — mes+año fijo (mayo 2026)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('agendaId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/agenda",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mes\": 5,\n  \"anio\": 2026\n}"
            }
          }
        },
        {
          "name": "Ver agenda con patrones",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/agenda/{{agendaId}}"
          }
        },
        {
          "name": "Eliminar agenda",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/agenda/{{agendaId}}"
          }
        },
        {
          "name": "Crear agenda — mes+año duplicado (debe dar error)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/agenda",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mes\": 5,\n  \"anio\": 2026\n}"
            }
          }
        },
        {
          "name": "Crear agenda — mes inválido (debe dar error)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/agenda",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mes\": 13,\n  \"anio\": 2026\n}"
            }
          }
        },
        {
          "name": "Ver agenda — no existe (debe dar 404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/agenda/99999"
          }
        }
      ]
    },
    {
      "name": "Clases — Patrones Recurrentes",
      "item": [
        {
          "name": "Listar patrones de la agenda",
          "request": {
