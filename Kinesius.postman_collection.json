            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/agenda/{{agendaId}}/recurrentes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"diaSemana\": 1,\n  \"hora\": \"8:00\",\n  \"zona\": \"ALTA\",\n  \"cupoMaximo\": 10,\n  \"precio\": 2000,\n  \"profesorId\": 1\n}"
            }
          }
