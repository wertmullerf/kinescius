            "url": "{{baseUrl}}/instancias/sueltas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"2026-07-10T11:00:00.000Z\",\n  \"zona\": \"ALTA\",\n  \"cupoMaximo\": 10,\n  \"precio\": 2000,\n  \"profesorId\": 99999\n}"
            }
          }
        },
        {
          "name": "Crear clase suelta — fecha inválida (debe dar error)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/instancias/sueltas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"no-es-una-fecha\",\n  \"zona\": \"ALTA\",\n  \"cupoMaximo\": 10,\n  \"precio\": 2000,\n  \"profesorId\": 1\n}"
            }
          }
        },
        {
          "name": "Eliminar clase suelta",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/instancias/sueltas/{{sueltaId}}"
          }
        },
        {
          "name": "Eliminar clase suelta — como CLIENTE (debe dar 403)",
          "request": {
