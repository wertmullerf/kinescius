            "url": "{{baseUrl}}/agenda/{{agendaId}}/recurrentes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"diaSemana\": 2,\n  \"hora\": \"10:00\",\n  \"zona\": \"BAJA\",\n  \"cupoMaximo\": 10,\n  \"precio\": 1000,\n  \"profesorId\": 99999\n}"
            }
          }
        },
        {
          "name": "Editar patrón — cambiar precio y cupo (propaga a instancias)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/agenda/{{agendaId}}/recurrentes/{{patronId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"precio\": 2500,\n  \"cupoMaximo\": 12\n}"
            }
          }
        },
        {
          "name": "Editar patrón — cambiar diaSemana (regenera instancias)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/agenda/{{agendaId}}/recurrentes/{{patronId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"diaSemana\": 2\n}"
            }
          }
        },
        {
          "name": "Eliminar patrón",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/agenda/{{agendaId}}/recurrentes/{{patronId}}"
          }
        },
        {
          "name": "Editar patrón — como CLIENTE (debe dar 403)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenCliente}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/agenda/{{agendaId}}/recurrentes/{{patronId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"precio\": 999\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Clases — Instancias",
      "item": [
        {
          "name": "Listar instancias del mes",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
                  "  pm.collectionVariables.set('instanciaId', json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/agenda/{{agendaId}}/instancias"
          }
        },
        {
          "name": "Listar instancias (como CLIENTE)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenCliente}}" }],
            "url": "{{baseUrl}}/agenda/{{agendaId}}/instancias"
          }
        },
        {
          "name": "Editar instancia — excepción (cambio de profesor)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/instancias/{{instanciaId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profesorId\": 2,\n  \"motivoExcepcion\": \"Juan Pérez está de licencia ese día\"\n}"
            }
          }
        },
        {
          "name": "Editar instancia — sin motivoExcepcion (debe dar error)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/instancias/{{instanciaId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cupoMaximo\": 5\n}"
            }
          }
        },
        {
          "name": "Cancelar instancia",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/instancias/{{instanciaId}}/cancelar"
          }
        },
        {
          "name": "Editar instancia — como CLIENTE (debe dar 403)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenCliente}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/instancias/{{instanciaId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cupoMaximo\": 5,\n  \"motivoExcepcion\": \"test\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Clases — Sueltas",
      "item": [
        {
          "name": "Crear clase suelta",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Próximo martes a las 15:00",
                  "const now = new Date();",
                  "const diasHastaMartes = (2 - now.getDay() + 7) % 7 || 7;",
                  "const martes = new Date(now);",
                  "martes.setDate(now.getDate() + diasHastaMartes);",
                  "martes.setHours(15, 0, 0, 0);",
                  "pm.variables.set('fechaSuelta', martes.toISOString());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('sueltaId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/instancias/sueltas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"{{fechaSuelta}}\",\n  \"zona\": \"BAJA\",\n  \"cupoMaximo\": 6,\n  \"precio\": 1200,\n  \"profesorId\": 3\n}"
            }
          }
        },
        {
          "name": "Crear clase suelta — fecha fija manual",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/instancias/sueltas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"2026-06-15T10:00:00.000Z\",\n  \"zona\": \"MEDIA\",\n  \"cupoMaximo\": 8,\n  \"precio\": 1800,\n  \"profesorId\": 1\n}"
            }
          }
        },
        {
          "name": "Crear clase suelta — profesor inexistente (debe dar error)",
