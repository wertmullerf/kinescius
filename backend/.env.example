# Mercado Pago
MP_ACCESS_TOKEN=TEST-...
MP_PUBLIC_KEY=TEST-...
MP_SUCCESS_URL=http://localhost:5173/pago/exito
MP_FAILURE_URL=http://localhost:5173/pago/error
MP_PENDING_URL=http://localhost:5173/pago/pendiente
# URL pública del webhook (usar ngrok en desarrollo: https://xxxx.ngrok.io/api/pagos/webhook)
MP_WEBHOOK_URL= https://73l0vd1l-3000.brs.devtunnels.ms/api/pagos/webhook

# Resend (mailing)
RESEND_API_KEY=re_...
