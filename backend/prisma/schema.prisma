// Prisma schema — Kinesius
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Rol {
  ADMIN
  PROFESOR
  CLIENTE
}

enum TipoCliente {
  ABONADO
  NO_ABONADO
}

enum ZonaClase {
  ALTA
  MEDIA
  BAJA
}

enum EstadoReserva {
  PENDIENTE_PAGO   // no abonado: esperando el 50% de seña
  RESERVA_PAGA     // no abonado: seña pagada, esperando el resto presencial
  CONFIRMADA       // abonado: ya pagó el abono, reserva confirmada
  CANCELADA
  COMPLETADA       // clase finalizada y asistencia registrada
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  MERCADO_PAGO
}

enum TipoPago {
  SENA         // 50% inicial del no abonado
  COMPLEMENTO  // 50% restante que registra el admin presencialmente
  ABONO        // pago adelantado del abonado (mínimo 3 clases)
}

// ─────────────────────────────────────────
// USUARIO
// Representa las cuentas de acceso al sistema.
// ADMIN: 1 cuenta precargada por seed.
// PROFESOR: 1 cuenta compartida precargada por seed (para registrar asistencia).
// CLIENTE: se registran desde la API.
// ─────────────────────────────────────────

model Usuario {
  id          Int         @id @default(autoincrement())
  nombre      String
  apellido    String
  dni         String      @unique
  email       String      @unique
  password    String      // almacenado como hash bcrypt
  rol         Rol
  tipoCliente       TipoCliente @default(NO_ABONADO) // solo aplica cuando rol == CLIENTE; el sistema lo gestiona, no el usuario
  clasesDisponibles Int         @default(0)           // solo aplica cuando rol == CLIENTE; el sistema lo gestiona
  sancionado        Boolean     @default(false)        // solo aplica cuando rol == CLIENTE y tipoCliente == ABONADO; se levanta con el próximo abono
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  reservas      Reserva[]
  colasEspera   ColaEspera[]
  abonosPagados PagoAbono[]

  @@map("usuarios")
}

// ─────────────────────────────────────────
// PROFESOR
// Tabla separada de Usuario. Almacena los datos de los profesores
// reales del centro para asignarlos a clases.
// No tienen cuenta de acceso individual; comparten la cuenta PROFESOR.
// ─────────────────────────────────────────

model Profesor {
  id       Int    @id @default(autoincrement())
  nombre   String
  apellido String
  dni      String @unique

  clasesRecurrentes ClaseRecurrente[]
  claseInstancias   ClaseInstancia[]

  @@map("profesores")
}

// ─────────────────────────────────────────
// AGENDA MENSUAL
// Agrupa los patrones recurrentes de un mes calendario.
// ─────────────────────────────────────────

model AgendaMensual {
  id     Int    @id @default(autoincrement())
  mes    Int    // 1–12
  anio   Int

  clases ClaseRecurrente[]

  @@unique([mes, anio])
  @@map("agendas_mensuales")
}

// ─────────────────────────────────────────
// CLASE RECURRENTE
// Patrón que define una clase que se repite cada semana en un día
// y hora fijos dentro de una agenda mensual. A partir de este patrón
// el sistema genera automáticamente las ClaseInstancia del mes.
// ─────────────────────────────────────────

model ClaseRecurrente {
  id        Int       @id @default(autoincrement())
  diaSemana Int       // 0=domingo, 1=lunes, ..., 6=sábado
  hora      DateTime  // solo se usa la parte de hora HH:mm
  zona      ZonaClase
  cupoMaximo Int
  duracion  Int       @default(60) // duración en minutos
  precio    Decimal   @db.Decimal(10, 2)

  profesorId Int
  profesor   Profesor @relation(fields: [profesorId], references: [id])

  agendaId Int
  agenda   AgendaMensual @relation(fields: [agendaId], references: [id])

  instancias ClaseInstancia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clases_recurrentes")
}

// ─────────────────────────────────────────
// CLASE INSTANCIA
// Ocurrencia concreta de una clase en un día y hora específicos.
// Puede originarse de un patrón recurrente (recurrenteId presente)
// o crearse de forma suelta sin patrón (recurrenteId null).
// Si esExcepcion=true, alguno de sus campos difiere del patrón
// (ej: cambio de profesor urgente) y motivoExcepcion es obligatorio
// (se valida en la capa de negocio, no en DB).
// ─────────────────────────────────────────

model ClaseInstancia {
  id              Int       @id @default(autoincrement())
  fecha           DateTime  // día y hora concretos de esta clase
  zona            ZonaClase
  cupoMaximo      Int
  duracion        Int       @default(60) // duración en minutos
  precio          Decimal   @db.Decimal(10, 2)
  codigoQr        String    @unique @default(cuid())
  esExcepcion     Boolean   @default(false)
  motivoExcepcion String?   // obligatorio si esExcepcion=true; se valida en la lógica de negocio

  profesorId Int
  profesor   Profesor @relation(fields: [profesorId], references: [id])

  recurrenteId Int?              // null si es una instancia suelta (no generada desde un patrón)
  recurrente   ClaseRecurrente? @relation(fields: [recurrenteId], references: [id])

  reservas    Reserva[]
  colasEspera ColaEspera[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([fecha, profesorId])  // un profesor no puede dar dos clases al mismo tiempo

  @@map("clases_instancias")
}

// ─────────────────────────────────────────
// RESERVA
// ─────────────────────────────────────────

model Reserva {
  id          Int           @id @default(autoincrement())
  estado      EstadoReserva @default(PENDIENTE_PAGO)
  montoPagado Decimal       @db.Decimal(10, 2) @default(0) // total pagado hasta el momento
  mpPrefId    String?       // id de la preferencia MP (solo no abonados, mientras PENDIENTE_PAGO)

  clienteId Int
  cliente   Usuario @relation(fields: [clienteId], references: [id])

  instanciaId Int
  instancia   ClaseInstancia @relation(fields: [instanciaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pagos      Pago[]
  asistencia Asistencia?

  // Índice único parcial gestionado por migración manual:
  // UNIQUE (clienteId, instanciaId) WHERE estado NOT IN ('CANCELADA', 'COMPLETADA')
  // Permite volver a reservar la misma instancia si la reserva anterior fue cancelada.
  @@map("reservas")
}

// ─────────────────────────────────────────
// PAGO
// ─────────────────────────────────────────

model Pago {
  id         Int        @id @default(autoincrement())
  monto      Decimal    @db.Decimal(10, 2)
  metodo     MetodoPago
  tipo       TipoPago
  referencia String?    // número de transferencia, recibo, etc.

  reservaId Int
  reserva   Reserva @relation(fields: [reservaId], references: [id])

  createdAt DateTime @default(now())

  logs PagoLog[]

  @@map("pagos")
}

// ─────────────────────────────────────────
// PAGO LOG
// Registra todos los eventos de pago del sistema para auditoría.
// ─────────────────────────────────────────

model PagoLog {
  id            Int      @id @default(autoincrement())
  pagoId        Int
  pago          Pago     @relation(fields: [pagoId], references: [id])
  evento        String   // "CREADO", "APROBADO", "REVERTIDO", "FALLIDO", "PENDIENTE"
  mpPaymentId   String?  // id del pago en MP (si aplica)
  mpStatus      String?  // status devuelto por MP
  mpRawResponse Json?    // respuesta cruda de MP para debugging
  solicitadoPor Int?     // id del usuario que disparó el evento
  createdAt     DateTime @default(now())

  @@map("pago_logs")
}

// ─────────────────────────────────────────
// ASISTENCIA
// ─────────────────────────────────────────

model Asistencia {
  id            Int     @id @default(autoincrement())
  presente      Boolean @default(false)
  registradoPor Int?    // id del usuario que registró (profesor o admin)

  reservaId Int     @unique // una reserva tiene como máximo un registro de asistencia
  reserva   Reserva @relation(fields: [reservaId], references: [id])

  createdAt DateTime @default(now())

  @@map("asistencias")
}

// ─────────────────────────────────────────
// COLA DE ESPERA
// ─────────────────────────────────────────

model ColaEspera {
  id       Int       @id @default(autoincrement())
  posicion Int       // orden en la cola (abonados tienen prioridad)
  expiraEn DateTime? // hasta cuándo tiene para confirmar (5hs desde notificación)

  instanciaId Int
  instancia   ClaseInstancia @relation(fields: [instanciaId], references: [id])

  clienteId Int
  cliente   Usuario @relation(fields: [clienteId], references: [id])

  createdAt DateTime @default(now())

  @@unique([instanciaId, clienteId])
  @@unique([instanciaId, posicion])
  @@map("cola_espera")
}

// ─────────────────────────────────────────
// PAGO ABONO
// Registra los abonos cargados a un cliente (presencial o vía MP).
// Separado de Pago porque los abonos no están ligados a ninguna reserva.
// ─────────────────────────────────────────

model PagoAbono {
  id             Int        @id @default(autoincrement())
  clienteId      Int
  cliente        Usuario    @relation(fields: [clienteId], references: [id])
  cantidadClases Int
  monto          Decimal    @db.Decimal(10, 2)
  metodo         MetodoPago
  referencia     String?    // número de recibo, transferencia, etc.
  mpPaymentId    String?    // id del pago en MP si fue vía webhook
  mpRawResponse  Json?      // respuesta cruda de MP para debugging
  createdAt      DateTime   @default(now())

  @@map("pagos_abono")
}
